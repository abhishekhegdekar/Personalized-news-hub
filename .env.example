# Copy this file to .env and fill in your values
# This file is safe to commit; .env is gitignored

# MySQL
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=news_hub
MYSQL_USER=newsflow
MYSQL_PASSWORD=your_db_password

# NewsFlow DB connection (must match MYSQL_* above)
NEWSFLOW_DB_HOST=db
NEWSFLOW_DB_PORT=3306
NEWSFLOW_DB_NAME=news_hub
NEWSFLOW_DB_USER=newsflow
NEWSFLOW_DB_PASS=your_db_password

# News API Keys
# NewsAPI.org (https://newsapi.org) — free tier available
NEWSFLOW_API_KEY_1=your_newsapi_key

# World News API (https://worldnewsapi.com) — free tier available
NEWSFLOW_API_KEY_2=your_worldnewsapi_key
